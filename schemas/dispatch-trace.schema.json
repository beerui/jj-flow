{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beerui.github.io/jj-flow/schemas/dispatch-trace.schema.json",
  "title": "jj-flow deterministic trace envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "scenario", "delivery_id", "created_at", "context", "initial_state", "initial_hash", "steps", "final_hash", "external_actions_recorded"],
  "properties": {
    "schema_version": { "const": "jj-flow/trace/1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "scenario": { "type": "string", "minLength": 1 },
    "delivery_id": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "context": { "type": "object" },
    "initial_state": { "type": "object" },
    "initial_hash": { "$ref": "#/$defs/hash" },
    "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } },
    "final_hash": { "$ref": "#/$defs/hash" },
    "external_actions_recorded": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "operation", "input", "revision_before", "revision_after", "before_hash", "after_hash", "output", "output_hash", "evidence_refs"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "operation": { "type": "string", "minLength": 1 },
        "input": { "type": "object" },
        "revision_before": { "type": ["integer", "null"], "minimum": 0 },
        "revision_after": { "type": ["integer", "null"], "minimum": 0 },
        "before_hash": { "$ref": "#/$defs/hash" },
        "after_hash": { "$ref": "#/$defs/hash" },
        "output": { "type": "object" },
        "output_hash": { "$ref": "#/$defs/hash" },
        "evidence_refs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
