{
  "name": "@shendu-sdt/jj-flow",
  "version": "0.1.1-beta.8",
  "description": "jj-flow project-level AI delivery workflow adapter for Maestro.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beerui/jj-flow.git"
  },
  "homepage": "https://beerui.github.io/jj-flow/index.html",
  "bin": {
    "jj": "bin/jj.mjs",
    "jj-flow": "bin/jj.mjs"
  },
  "files": [
    ".claude/commands/",
    ".codex/skills/",
    "bin/",
    "src/",
    "workflows/",
    "examples/",
    "docs/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "check": "node scripts/check-project.mjs",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:check": "node scripts/build-docs.mjs --check",
    "verify": "npm test && npm run check && npm run docs:check"
  },
  "keywords": [
    "maestro",
    "codex",
    "workflow",
    "ai-delivery"
  ],
