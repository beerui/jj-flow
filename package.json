{
  "name": "@shendu-sdt/jj-flow",
  "version": "0.1.1-beta.18",
  "description": "Project-family orchestration workflow: cross-repo migration (same) and multi-project dispatch.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beerui/jj-flow.git"
  },
  "homepage": "https://beerui.github.io/jj-flow/index.html",
  "bin": {
    "jj": "bin/jj.mjs",
    "jj-flow": "bin/jj.mjs"
  },
  "files": [
    ".claude/commands/",
    ".codex/skills/",
    ".codex/agents/",
    "bin/",
    "src/",
    "scripts/check-harness.mjs",
    "schemas/",
    "harness-manifest.json",
    "workflows/",
    "examples/",
    "docs/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "check": "node scripts/check-project.mjs",
    "doctor": "node bin/jj.mjs doctor --json",
    "harness:check": "node scripts/check-harness.mjs",
    "scenario:check": "node bin/jj.mjs scenario check --json",
    "host:trial": "node bin/jj.mjs host-trial run --json",
    "harness:gc": "node bin/jj.mjs harness-gc --json",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:check": "node scripts/build-docs.mjs --check",
    "verify": "npm test && npm run check && npm run harness:check && npm run harness:gc && npm run scenario:check && npm run host:trial && npm run docs:check"
  },
  "keywords": [
    "project-family",
    "orchestration",
    "workflow",
    "codex",
    "dispatch",
    "migration"
  ],
  "author": "jj-flow",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  }
}
